{
  "name": "@teachanything/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npm run db:setup-extensions && drizzle-kit migrate",
    "db:setup-extensions": "tsx scripts/setup-extensions.ts",
    "db:setup-rls": "tsx scripts/setup-rls-policies.ts",
    "db:push": "npm run db:setup-extensions && drizzle-kit push --force",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.8",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
